# =============================================================================
# Subscription Relay Proxy — Настройки (.env)
# =============================================================================
# Скопируйте этот файл в .env и заполните значения:
#   cp env.example .env
# =============================================================================
#
# Поддерживается два формата:
#   1. Legacy (одиночный сервер) — НЕ задавайте SERVERS
#   2. Мульти-сервер — задайте SERVERS=NL,DE и переменные с префиксами
#
# Поддерживаются два формата подписок на upstream:
#   a) Токен в пути: https://xui-server/sub_path/<TOKEN>
#      → клиент: https://relay:5443/xui-sub/<TOKEN>
#   b) Параметры в query: https://xui-server/sub_path?param=value&s=<UUID>
#      → клиент: https://relay:5443/xui-sub-de/?param=value&s=<UUID>
#
# =============================================================================

# ── Порт и хост sub_proxy.py (общие для всех серверов) ────────────────────
SUB_PROXY_HOST=127.0.0.1
SUB_PROXY_PORT=9080

# ── Таймаут запроса к 3x-ui (секунды) ───────────────────────────────────────
UPSTREAM_TIMEOUT=10

# ── Проверка SSL-сертификата upstream ──────────────────────────────────────
# true  — проверять сертификат upstream (по умолчанию, рекомендуется)
# false — отключить проверку (ТОЛЬКО для самоподписанных сертификатов, MITM-риск!)
UPSTREAM_SSL_VERIFY=true

# ── Порт relay-сервера (для формирования внешних ссылок) ─────────────────────
# Если relay слушает на нестандартном порту (например 5443), укажите его здесь.
# Используется при формировании deep-link URL (sing-box://import-remote-profile).
# Можно задать глобально (RELAY_PORT) или для каждого сервера (<NAME>_RELAY_PORT).
RELAY_PORT=5443

# ── Белый список JSON-ключей для замены в sing-box конфиге ────────────────────
# Адреса заменяются ТОЛЬКО в ключах из SINGBOX_ADDR_KEYS (через запятую).
# Порты заменяются ТОЛЬКО в ключах из SINGBOX_PORT_KEYS (через запятую).
# Всё остальное (server_name/SNI, domain, domain_suffix, ip_cidr) — не трогается.
#
# По умолчанию: server / server_port — подходит для стандартных sing-box конфигов.
# Добавляйте ключи, только если upstream генерирует нестандартные конфиги.
SINGBOX_ADDR_KEYS=server
SINGBOX_PORT_KEYS=server_port


# =============================================================================
# Вариант 1: Legacy — одиночный сервер (если SERVERS не задана)
# =============================================================================

# XUI_SUB_BASE_URL=https://YOUR-XUI-IP.sslip.io/secret_sub_path
# RELAY_ADDRESS=YOUR-RELAY-IP.sslip.io
# XUI_ADDRESSES=XUI_IP,YOUR-XUI-IP.sslip.io
# PORT_MAP=443:8443,4443:9443


# =============================================================================
# Вариант 2: Мульти-сервер
# =============================================================================
# Список серверов через запятую (имена → станут префиксами переменных)
SERVERS=NL,DE

# ── Сервер NL ─────────────────────────────────────────────────────────────
# Формат подписки: токен в пути
# Клиент: https://relay:5443/xui-sub/<TOKEN>
# Upstream: https://NL-XUI-IP.sslip.io/secret_path/<TOKEN>
NL_XUI_SUB_BASE_URL=https://YOUR-NL-XUI-IP.sslip.io/secret_sub_path
NL_RELAY_ADDRESS=YOUR-RELAY-IP.sslip.io
NL_XUI_ADDRESSES=NL_XUI_IP,YOUR-NL-XUI-IP.sslip.io
NL_PORT_MAP=443:8443,4443:9443
NL_PATH_PREFIX=/xui-sub/

# ── Сервер DE ─────────────────────────────────────────────────────────────
# Формат подписки: параметры в query string (?t=si&r=si&s=UUID)
# Клиент: https://relay:5443/xui-sub-de/?t=si&r=si&s=<UUID>#profile_name
#   (#profile_name — fragment, не отправляется серверу, используется клиентом)
# Upstream: https://DE-XUI-IP.sslip.io/secret_path?t=si&r=si&s=<UUID>
DE_XUI_SUB_BASE_URL=https://YOUR-DE-XUI-IP.sslip.io/secret_path
DE_RELAY_ADDRESS=YOUR-RELAY-IP.sslip.io
DE_XUI_ADDRESSES=DE_XUI_IP,YOUR-DE-XUI-IP.sslip.io
DE_PORT_MAP=
DE_PATH_PREFIX=/xui-sub-de/
