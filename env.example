# =============================================================================
# Subscription Relay — Настройки
# =============================================================================
# Скопируйте этот файл в .env и заполните значения:
#   cp env.example .env
# =============================================================================

# ── Relay-сервер ──────────────────────────────────────────────────────────────
RELAY_DOMAIN=relay.example.com        # Домен relay-сервера (должен быть направлен на relay)
RELAY_IP=1.2.3.4                       # Внешний IP relay-сервера

# ── 3x-ui сервер ─────────────────────────────────────────────────────────────
XUI_HOST=5.6.7.8                       # IP или домен 3x-ui сервера
XUI_IP=5.6.7.8                         # IP 3x-ui (для замены в подписках)
XUI_SUB_PORT=2096                      # Порт, на котором 3x-ui отдаёт подписку
SUB_PATH=/sub/                         # Путь подписки на 3x-ui

# ── Порты VPN-трафика (relay → 3x-ui) ────────────────────────────────────────
RELAY_VLESS_PORT=443                   # Порт на relay для VLESS/Trojan
XUI_VLESS_PORT=443                     # Порт на 3x-ui для VLESS/Trojan

# Если есть дополнительные inbound-ы, добавьте:
# RELAY_VMESS_PORT=8080
# XUI_VMESS_PORT=8080
