# =============================================================================
# Subscription Relay Proxy — Настройки (.env)
# =============================================================================
# Скопируйте этот файл в .env и заполните значения:
#   cp env.example .env
# =============================================================================
#
# Поддерживается два формата:
#   1. Legacy (одиночный сервер) — НЕ задавайте SERVERS
#   2. Мульти-сервер — задайте SERVERS=NL,DE и переменные с префиксами
#
# Поддерживаются два формата подписок на upstream:
#   a) Токен в пути: https://xui-server/sub_path/<TOKEN>
#      → клиент: https://relay:5443/xui-sub/<TOKEN>
#   b) Параметры в query: https://xui-server/sub_path?param=value&s=<UUID>
#      → клиент: https://relay:5443/xui-sub-de/?param=value&s=<UUID>
#
# =============================================================================

# ── Порт и хост sub_proxy.py (общие для всех серверов) ────────────────────
SUB_PROXY_HOST=127.0.0.1
SUB_PROXY_PORT=9080

# ── Таймаут запроса к 3x-ui (секунды) ───────────────────────────────────────
UPSTREAM_TIMEOUT=10

# ── Проверка SSL-сертификата upstream ──────────────────────────────────────
# true  — проверять сертификат upstream (по умолчанию, рекомендуется)
# false — отключить проверку (ТОЛЬКО для самоподписанных сертификатов, MITM-риск!)
UPSTREAM_SSL_VERIFY=true

# ── Порт relay-сервера (для формирования внешних ссылок) ─────────────────────
# Если relay слушает на нестандартном порту (например 5443), укажите его здесь.
# Используется при формировании deep-link URL (sing-box://import-remote-profile).
# Можно задать глобально (RELAY_PORT) или для каждого сервера (<NAME>_RELAY_PORT).
RELAY_PORT=5443


# =============================================================================
# Настройки замены в sing-box JSON конфигах
# =============================================================================
#
# Как работают замены:
#
#   1. SINGBOX_REPLACE_TAGS — В КАКИХ объектах менять (по "tag")
#   2. SINGBOX_ADDR_KEYS    — КАКИЕ JSON-ключи содержат адрес для замены
#   3. SINGBOX_PORT_KEYS    — КАКИЕ JSON-ключи содержат порт для замены
#   4. RELAY_ADDRESS        — НА ЧТО менять адрес (IP или домен relay-сервера)
#   5. PORT_MAP             — НА ЧТО менять порт (маппинг src:dst)
#
# Пример для конфига с relay 193.233.231.208 и XUI 150.241.90.145:
#
#   SINGBOX_REPLACE_TAGS=proxy
#   RELAY_ADDRESS=193-233-231-208.sslip.io
#   XUI_ADDRESSES=150.241.90.145,150-241-90-145.sslip.io
#   PORT_MAP=443:8443
#
#   Результат — замена ТОЛЬКО в outbound "proxy":
#     "server": "150-241-90-145.sslip.io" → "193-233-231-208.sslip.io"
#     "server_port": 443                  → 8443
#
#   НЕ затрагиваются (tag не совпал):
#     dns "dns-remote"  server: "8.8.8.8"                  — без изменений
#     dns "dns_direct"  server: "150-241-90-145.sslip.io"  — без изменений
#     outbound "warpSOCKS5" server: "10.10.0.13"           — без изменений
#     inbound http_proxy server: "127.0.0.1"               — без изменений
#
# =============================================================================

# ── Привязка замен к тегам (tag) ─────────────────────────────────────────────
# Через запятую перечислите теги объектов, в которых нужно заменять адрес и порт.
# Замена server/server_port происходит ТОЛЬКО в объектах с совпадающим "tag".
#
# Примеры:
#   SINGBOX_REPLACE_TAGS=proxy              — только outbound "proxy"
#   SINGBOX_REPLACE_TAGS=proxy,warpSOCKS5   — два outbound-а
#   (пусто)                                 — legacy-режим: замена везде
#
# Рекомендуется задавать — это точнее и безопаснее для DNS-секции.
SINGBOX_REPLACE_TAGS=proxy

# ── Белый список JSON-ключей для замены адресов/портов ────────────────────────
# Адреса заменяются ТОЛЬКО в ключах из SINGBOX_ADDR_KEYS.
# Порты заменяются ТОЛЬКО в ключах из SINGBOX_PORT_KEYS.
# Всё остальное (server_name/SNI, domain, domain_suffix, ip_cidr) — не трогается.
#
# По умолчанию: server / server_port — подходит для стандартных sing-box конфигов.
# Добавляйте ключи, только если upstream генерирует нестандартные конфиги.
SINGBOX_ADDR_KEYS=server
SINGBOX_PORT_KEYS=server_port

# ── Белый список ключей для замены плейсхолдеров ~domain~ / ~dnspath~ ─────────
# Работают ВЕЗДЕ, независимо от SINGBOX_REPLACE_TAGS (привязки к тегам нет).
# Плейсхолдер ~domain~ заменяется на DOMAIN_REPLACE ТОЛЬКО в значениях ключей
# из SINGBOX_DOMAIN_KEYS. Плейсхолдер ~dnspath~ — только в SINGBOX_DNS_PATH_KEYS.
#
# Что НЕ затрагивается (ключи вне белого списка):
#   "domain": "~domain~"     в route rules — НЕ заменяется
#   "predefined": {"~domain~": ...}  в dns hosts — НЕ заменяется (это ключ объекта)
#
# По умолчанию: server / path — подходит для стандартных sing-box DNS конфигов.
SINGBOX_DOMAIN_KEYS=server
SINGBOX_DNS_PATH_KEYS=path


# =============================================================================
# Вариант 1: Legacy — одиночный сервер (если SERVERS не задана)
# =============================================================================

# XUI_SUB_BASE_URL=https://150-241-90-145.sslip.io/secret_sub_path
# RELAY_ADDRESS=193-233-231-208.sslip.io
# XUI_ADDRESSES=150.241.90.145,150-241-90-145.sslip.io
# PORT_MAP=443:8443


# =============================================================================
# Вариант 2: Мульти-сервер
# =============================================================================
# Список серверов через запятую (имена → станут префиксами переменных)
SERVERS=NL,DE

# ── Сервер NL ─────────────────────────────────────────────────────────────
# Формат подписки: токен в пути
# Клиент: https://relay:5443/xui-sub/<TOKEN>
# Upstream: https://150-241-90-145.sslip.io/secret_path/<TOKEN>
NL_XUI_SUB_BASE_URL=https://150-241-90-145.sslip.io/secret_sub_path

# НА ЧТО заменять адрес — IP или домен relay-сервера.
# Используйте домен (sslip.io) если в конфиге есть dns-hosts с predefined
# для резолва домена в IP. Используйте IP для прямого подключения.
NL_RELAY_ADDRESS=193-233-231-208.sslip.io

# КАКИЕ адреса искать для замены — IP и домены XUI-сервера (через запятую).
# Все вхождения этих значений в "server" (в тегах из SINGBOX_REPLACE_TAGS)
# будут заменены на RELAY_ADDRESS.
NL_XUI_ADDRESSES=150.241.90.145,150-241-90-145.sslip.io

# Маппинг портов XUI:RELAY (через запятую).
# Порт заменяется в "server_port" (в тегах из SINGBOX_REPLACE_TAGS).
# Пусто = порт не меняется.
#   Пример: PORT_MAP=443:8443   → server_port 443 станет 8443
#   Пример: PORT_MAP=443:8443,4443:9443 → два маппинга
NL_PORT_MAP=443:8443

NL_PATH_PREFIX=/xui-sub/

# Замена плейсхолдеров ~domain~ / ~dnspath~ в sing-box JSON.
# Работают ВЕЗДЕ (не привязаны к тегам из SINGBOX_REPLACE_TAGS).
# ~domain~ заменяется ТОЛЬКО в ключах из SINGBOX_DOMAIN_KEYS (по умолчанию: server)
# ~dnspath~ заменяется ТОЛЬКО в ключах из SINGBOX_DNS_PATH_KEYS (по умолчанию: path)
# Используются когда в шаблоне 3x-ui остались литералы ~domain~ / ~dnspath~.
# Если 3x-ui уже подставил реальные адреса — эти переменные не нужны.
# Оставьте пустым чтобы отключить.
NL_DOMAIN_REPLACE=
NL_DNS_PATH_REPLACE=

# ── Сервер DE ─────────────────────────────────────────────────────────────
# Формат подписки: параметры в query string (?t=si&r=si&s=UUID)
# Клиент: https://relay:5443/xui-sub-de/?t=si&r=si&s=<UUID>#profile_name
#   (#profile_name — fragment, не отправляется серверу, используется клиентом)
# Upstream: https://DE-XUI-IP.sslip.io/secret_path?t=si&r=si&s=<UUID>
DE_XUI_SUB_BASE_URL=https://YOUR-DE-XUI-IP.sslip.io/secret_path
DE_RELAY_ADDRESS=193-233-231-208.sslip.io
DE_XUI_ADDRESSES=DE_XUI_IP,YOUR-DE-XUI-IP.sslip.io
DE_PORT_MAP=
DE_PATH_PREFIX=/xui-sub-de/
DE_DOMAIN_REPLACE=
DE_DNS_PATH_REPLACE=
