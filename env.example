# =============================================================================
# Subscription Relay Proxy — Настройки (.env)
# =============================================================================
# Скопируйте этот файл в .env и заполните значения:
#   cp env.example .env
# =============================================================================

# ── URL подписки на 3x-ui сервере ───────────────────────────────────────────
# Полный URL включая путь подписки (без токена клиента).
# sub_proxy.py стрипает relay-префикс (/xui-sub/) и добавляет токен к этому URL.
# Пример: клиент запрашивает /xui-sub/<token>
#   → sub_proxy.py стрипает /xui-sub/ → остаётся /<token>
#   → запрос: https://44-44-44-44.sslip.io/Rwdds1XehitLaIPO/<token>
XUI_SUB_BASE_URL=https://44-44-44-44.sslip.io/Rwdds1XehitLaIPO

# ── Адрес relay-сервера (будет подставлен в подписку) ────────────────────────
# Домен или IP relay-сервера, который увидит клиент в VPN-конфиге.
RELAY_ADDRESS=11.11.11.11.sslip.io

# ── IP/домены 3x-ui которые нужно заменить ───────────────────────────────────
# Через запятую. Все вхождения будут заменены на RELAY_ADDRESS.
XUI_ADDRESSES=44.44.44.44,44.44.44.44.sslip.io

# ── Маппинг портов: XUI_PORT:RELAY_PORT ─────────────────────────────────────
# Через запятую. Порты 3x-ui → порты на relay-сервере (из nftables DNAT).
#
# Из вашего nftables:
#   Клиент → relay:8443  → DNAT → 3x-ui(NL):443   (VLESS)
#   Клиент → relay:9443  → DNAT → 3x-ui(NL):4443  (MTProto)
#
# Формат: ПОРТ_3XUI:ПОРТ_RELAY
PORT_MAP=443:8443,4443:9443

# ── Порт и хост sub_proxy.py ────────────────────────────────────────────────
SUB_PROXY_HOST=127.0.0.1
SUB_PROXY_PORT=9080

# ── Таймаут запроса к 3x-ui (секунды) ───────────────────────────────────────
UPSTREAM_TIMEOUT=10

# ── Проверка SSL-сертификата upstream ──────────────────────────────────────
# По умолчанию false — 3x-ui обычно использует самоподписанный сертификат
UPSTREAM_SSL_VERIFY=false
