# =============================================================================
# Subscription Relay Proxy — Настройки (.env)
# =============================================================================
# Скопируйте этот файл в .env и заполните значения:
#   cp env.example .env
# =============================================================================
#
# Поддерживается два формата:
#   1. Legacy (одиночный сервер) — НЕ задавайте SERVERS
#   2. Мульти-сервер — задайте SERVERS=NL,DE и переменные с префиксами
#
# =============================================================================

# ── Порт и хост sub_proxy.py (общие для всех серверов) ────────────────────
SUB_PROXY_HOST=127.0.0.1
SUB_PROXY_PORT=9080

# ── Таймаут запроса к 3x-ui (секунды) ───────────────────────────────────────
UPSTREAM_TIMEOUT=10

# ── Проверка SSL-сертификата upstream ──────────────────────────────────────
# false — для самоподписанных сертификатов (по умолчанию)
# true  — если 3x-ui использует валидный сертификат (Let's Encrypt и т.д.)
UPSTREAM_SSL_VERIFY=false


# =============================================================================
# Вариант 1: Legacy — одиночный сервер (если SERVERS не задана)
# =============================================================================

# XUI_SUB_BASE_URL=https://44-44-44-44.sslip.io/ReeIPO
# RELAY_ADDRESS=11.11.11.11.sslip.io
# XUI_ADDRESSES=44.44.44.44,44.44.44.44.sslip.io
# PORT_MAP=443:8443,4443:9443


# =============================================================================
# Вариант 2: Мульти-сервер
# =============================================================================
# Список серверов через запятую (имена → станут префиксами переменных)
SERVERS=NL,DE

# ── Сервер NL (Нидерланды) ────────────────────────────────────────────────
# Ссылка подписки: https://relay:5443/xui-sub/<TOKEN>
NL_XUI_SUB_BASE_URL=https://44-44-44-44.sslip.io/ReeIPO
NL_RELAY_ADDRESS=11.11.11.11.sslip.io
NL_XUI_ADDRESSES=44.44.44.44,44.44.44.44.sslip.io
NL_PORT_MAP=443:8443,4443:9443
NL_PATH_PREFIX=/xui-sub/

# ── Сервер DE (Германия) ──────────────────────────────────────────────────
# Ссылка подписки: https://relay:5443/xui-sub-de/<TOKEN>
DE_XUI_SUB_BASE_URL=https://55-55-55-55.sslip.io/AbCdEf
DE_RELAY_ADDRESS=11.11.11.11.sslip.io
DE_XUI_ADDRESSES=55.55.55.55,55.55.55.55.sslip.io
DE_PORT_MAP=443:7443,4443:6443
DE_PATH_PREFIX=/xui-sub-de/
